# Lightweight migration runner — has full Prisma CLI + all dependencies.
# Runs once at startup, deploys migrations, then exits.
FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY package*.json ./
COPY prisma/ ./prisma/

# Install all deps (prisma CLI is in devDependencies)
RUN npm ci && npx prisma generate

CMD ["npx", "prisma", "migrate", "deploy"]
