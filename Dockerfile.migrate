FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY package*.json ./
COPY prisma/ ./prisma/

RUN npm ci && npx prisma generate

COPY scripts/migrate-and-seed.sh ./scripts/

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 --ingroup nodejs migrate && \
    chown -R migrate:nodejs /app

USER migrate

CMD ["sh", "scripts/migrate-and-seed.sh"]
